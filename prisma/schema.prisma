generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/**
 * ----------------------------- Enums -----------------------------
 */

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum ListingStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AdditionalSetPricingType {
  FIXED
  HOURLY
}

/**
 * ---------------------------- Models -----------------------------
 */

model User {
  id                      String            @id @default(auto()) @map("_id") @db.ObjectId
  name                    String?
  email                   String?           @unique
  phone                   String?
  languages               String[]          @default([])
  location                String?
  description             String?
  profileImage            String?
  title                   String?
  emailVerified           DateTime?
  image                   String?
  hashedPassword          String?
  resetToken              String?
  resetTokenExpiry        DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  favoriteIds             String[]          @db.ObjectId
  accounts                Account[]
  listings                Listing[]
  reservations            Reservation[]
  CustomAmenities         CustomAmenities[]
  Review                  Review[]
  paymentDetails          PaymentDetails?   @relation("UserPaymentDetails")
  paymentDetailsId        String?           @db.ObjectId
  is_owner                Boolean           @default(false)
  is_verified             Boolean           @default(false)
  transactions            Transaction[]
  googleCalendarConnected Boolean           @default(false)
  billingDetails          BillingDetails[]
  invoices                Invoice[]
  markedForDeletion       Boolean           @default(false)
  markedForDeletionAt     DateTime?

  verification_stage Int       @default(0) // 0=none, 1=contact, 2=aadhaar, 3=bank
  aadhaar_verified   Boolean   @default(false)
  aadhaar_ref_id     String?
  bank_verified      Boolean   @default(false)
  bank_verified_name String?
  phone_verified     Boolean   @default(false)
  email_verified     Boolean   @default(false)
  verified_via       String[]  @default([]) // ["aadhaar_okyc", "phone_otp"]
  verified_at        DateTime?
  aadhaar_last4      String?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Listing {
  id                       String                    @id @default(auto()) @map("_id") @db.ObjectId
  title                    String
  slug                     String?                   @unique
  description              String
  imageSrc                 String[]
  createdAt                DateTime                  @default(now())
  category                 String
  locationValue            String
  actualLocation           Json?
  userId                   String                    @db.ObjectId
  price                    Int
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations             Reservation[]
  amenities                String[]
  otherAmenities           String[]
  addons                   Json?
  carpetArea               String?
  operationalDays          Json?
  operationalHours         Json?
  minimumBookingHours      String?
  maximumPax               String?
  instantBooking           Boolean?
  type                     String[]
  verifications            Json?
  terms                    Boolean?
  customTerms              String?
  Addons                   Addons[]
  reviews                  Review[]
  DayStatus                DayStatus[]
  avgReviewRating          Float?
  Transaction              Transaction[]
  packages                 Package[]
  status                   ListingStatus             @default(PENDING)
  active                   Boolean                   @default(false)
  hasSets                  Boolean                   @default(false)
  setsHaveSamePrice        Boolean                   @default(false)
  unifiedSetPrice          Int?
  additionalSetPricingType AdditionalSetPricingType?

  sets                     ListingSet[]

  blocks                   ListingBlock[]

  @@index([userId])
}

model Package {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String?
  originalPrice    Int
  offeredPrice     Int
  features         String[]
  durationHours    Int
  requiredSetCount Int?

  fixedAddOn       Int?
  eligibleSetIds   String[] @db.ObjectId
  isActive         Boolean  @default(true)
  listingId        String   @db.ObjectId
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

model DayStatus {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime
  listingActive Boolean
  startTime     String
  endTime       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  listingId     String   @db.ObjectId
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
}

model Reservation {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  userId              String          @db.ObjectId
  listingId           String          @db.ObjectId
  startDate           DateTime        @default(now())
  startTime           String
  endTime             String
  totalPrice          Float
  selectedAddons      Json?
  createdAt           DateTime        @default(now())
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing             Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  Review              Review[]
  isApproved          Int?
  rejectReason        String?
  Transaction         Transaction[]
  invoices            Invoice[]
  billingDetailId     String?         @db.ObjectId
  billingDetail       BillingDetails? @relation(fields: [billingDetailId], references: [id])
  markedForDeletion   Boolean         @default(false)
  markedForDeletionAt DateTime?
  setIds              String[]        @db.ObjectId
  includedSetId       String?         @db.ObjectId
  setPackageId        String?         @db.ObjectId
  pricingSnapshot     Json?
  totalPriceInt       Int?

  @@index([userId])
  @@index([listingId])
  @@index([billingDetailId])
  @@index([startDate])
}

model Amenities {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  icon      Json?
  createdAt DateTime @default(now())
}

model CustomAmenities {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Addons {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  image     String?
  price     Int
  createdAt DateTime @default(now())
  Listing   Listing? @relation(fields: [listingId], references: [id])
  listingId String?  @db.ObjectId

  @@index([listingId])
}

model Review {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  userId        String      @db.ObjectId
  listingId     String      @db.ObjectId
  reservationId String      @db.ObjectId
  rating        Float?
  comment       String
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing       Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@index([userId])
  @@index([listingId])
  @@index([reservationId])
}

model PaymentDetails {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                  String   @unique @db.ObjectId
  accountHolderName       String
  bankName                String
  accountNumber           String
  ifscCode                String
  companyName             String?
  gstin                   String?
  cashfreeVendorId        String?
  accountNumberIV         String?
  ifscCodeIV              String?
  gstinIV                 String?
  vendorIdIV              String?
  encryptionVersion       String?  @default("v1")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation("UserPaymentDetails", fields: [userId], references: [id])
}


model BillingDetails {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  companyName    String
  gstin          String // removed @db.VarChar
  billingAddress String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  reservations Reservation[]
  invoices     Invoice[]
}

model Transaction {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  userId        String            @db.ObjectId
  reservationId String?           @db.ObjectId
  listingId     String?           @db.ObjectId
  amount        Float
  currency      String            @default("INR")
  status        TransactionStatus @default(PENDING)
  description   String?
  paymentMethod String            @default("Cashfree")
  invoices      Invoice[]

  // -------- Cashfree PG fields ----------
  cfOrderId            String?
  cfPaymentId          String?
  cfTxnRef             String?
  cfPaymentSessionId   String?
  cfWebhookPayload     Json?
  cfSignature          String?
  emailSentCustomer    Boolean   @default(false)
  emailSentOwner       Boolean   @default(false)
  emailSentFailed      Boolean   @default(false)
  vendorId             String?
  payoutPercentToOwner Float?    @default(88)
  payoutDueAt          DateTime?
  payoutDoneAt         DateTime?
  
  // -------- GST Handling ----------
  gstOwnedBy           String?   @default("STUDIO") // "STUDIO" or "ARKANET"
  baseAmountBeforeGst  Float?    // Amount before GST (for calculation clarity)

  // -------- Common ----------
  customerPhone String?
  customerEmail String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  listing     Listing?     @relation(fields: [listingId], references: [id])

  @@index([userId])
  @@index([reservationId])
  @@index([listingId])
  @@index([status])
  @@index([payoutDueAt])
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String   @unique
  userId        String   @db.ObjectId
  reservationId String?  @db.ObjectId
  transactionId String?  @db.ObjectId
  billingId     String?  @db.ObjectId
  amount        Float
  gstAmount     Float?
  totalAmount   Float
  invoiceUrl    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  reservation    Reservation?    @relation(fields: [reservationId], references: [id])
  transaction    Transaction?    @relation(fields: [transactionId], references: [id])
  billingDetails BillingDetails? @relation(fields: [billingId], references: [id])
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ListingSet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId   String   @db.ObjectId
  name        String
  description String?
  images      String[]
  price       Int      @default(0)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}



model ListingBlock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId String   @db.ObjectId
  date      DateTime
  startTime String
  endTime   String
  setIds    String[] @db.ObjectId
  reason    String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, date])
}

